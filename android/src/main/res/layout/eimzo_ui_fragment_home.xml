<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F6">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:scaleType="centerCrop"
        android:src="@drawable/eimzo_ui_bg_sakura"
        android:contentDescription="@null" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Top bar: back/menu (left) + help (right) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="20dp">

                <!--
                  Back arrow — visible only when the activity was launched
                  via an eimzo:// deeplink. Tapping it returns the user to
                  the calling integrator app via finishAndRemoveTask().
                  In standalone-launch mode the menu icon is shown instead.
                -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/eimzo_ui_ic_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/eimzo_ui_back"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/btnMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="6dp"
                    android:src="@drawable/eimzo_ui_ic_menu"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/eimzo_ui_home" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btnHelp"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="4dp"
                    android:src="@drawable/eimzo_ui_ic_help"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/eimzo_ui_home" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="40dp" />

            <!-- Section header: "Mening kalitlarim" + "hammasi >" -->
            <LinearLayout
                android:id="@+id/headerKeys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/eimzo_ui_my_keys_full"
                    android:textColor="#1C1B1F"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/btnSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/eimzo_ui_see_all"
                        android:textColor="@color/eimzo_ui_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="2dp"
                        android:src="@drawable/eimzo_ui_ic_chevron_right"
                        app:tint="@color/eimzo_ui_primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Key card (populated state) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardKey"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:visibility="gone">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/eimzo_ui_gradient_card"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/lblHomeStir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/eimzo_ui_label_stir"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvKeyId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/lblHomeStir"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvKeyName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/lblHomeJshshir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/eimzo_ui_label_jshshir"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/tvKeyPinfl" />

                    <TextView
                        android:id="@+id/tvKeyPinfl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/guidelineHomeMid"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guidelineHomeMid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.55" />

                    <TextView
                        android:id="@+id/lblHomeDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/eimzo_ui_label_duration"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/guidelineHomeMid"
                        app:layout_constraintBottom_toTopOf="@id/tvKeyExpiry" />

                    <TextView
                        android:id="@+id/tvKeyExpiry"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/guidelineHomeMid"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <!--
                      "Muddati tugagan" badge — top-right pill, semi-transparent
                      red. Only shown when the certificate validTo timestamp is
                      in the past. Sits over the gradient so it's legible
                      regardless of the card's underlying color stops.
                    -->
                    <TextView
                        android:id="@+id/tvKeyExpiredBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/eimzo_ui_bg_expired_badge"
                        android:text="@string/eimzo_ui_key_expired"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Empty state card (no keys) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/tvNoKey"
                android:layout_width="match_parent"
                android:layout_height="360dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:background="#FFFFFF">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/eimzo_ui_ic_add"
                        app:tint="#9AA0A6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/eimzo_ui_new_key_add"
                        android:textColor="#9AA0A6"
                        android:textSize="16sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Deep link info -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDeepLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:background="#E8F7F1">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/eimzo_ui_deeplink_received"
                        android:textColor="@color/eimzo_ui_primary_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!--
                      Raw eimzo://sign?qc=... URL is intentionally not
                      surfaced to the user. The QR hash is meaningless to
                      a human reader and just clutters the UI; the deeplink
                      is still tracked in the ViewModel and used at sign
                      time. Kept in the binding (visibility=gone) for ABI
                      compatibility with any downstream layout overrides.
                    -->
                    <TextView
                        android:id="@+id/tvDeepLinkInfo"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                    <!--
                      Live countdown for the 103-second sign session that
                      started when the deeplink arrived. Drives user
                      urgency without forcing them out of the key-import
                      flow; auto-hides on session end.
                    -->
                    <TextView
                        android:id="@+id/tvSessionTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/eimzo_ui_primary_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- IMZOLASH button — signs with the currently selected saved key -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSign"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/eimzo_ui_sign"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/eimzo_ui_primary"
                android:visibility="gone" />

            <!-- USB token sign-only button — always visible, independent of
                 saved keys. Opens FT-reader session on tap, prompts for PIN,
                 signs the deeplink hash, tears the session down. Nothing
                 about the token is persisted to the keys DB. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignWithUsb"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:enabled="false"
                android:text="@string/eimzo_ui_usb_token_not_connected"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:icon="@drawable/eimzo_ui_ic_usb"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <!-- "Kalit qo'shish" divider section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#C0C4CC" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:text="@string/eimzo_ui_key_add_section"
                    android:textColor="#5F6368"
                    android:textSize="13sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#C0C4CC" />
            </LinearLayout>

            <!-- ERI qo'shish row -->
            <androidx.cardview.widget.CardView
                android:id="@+id/rowAddEri"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/eimzo_ui_add_eri_short"
                        android:textColor="#1C1B1F"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/eimzo_ui_ic_folder_add" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sign result -->
            <TextView
                android:id="@+id/tvSignResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="14sp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <!-- Legacy USB-only button kept hidden for binding compatibility -->
            <Space
                android:id="@+id/btnUsbToken"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
