<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/eimzo_ui_add_key"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddPfx"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:text="@string/eimzo_ui_add_eri_pfx"
        app:cornerRadius="12dp"
        app:icon="@drawable/eimzo_ui_ic_qr" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddNfc"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:text="@string/eimzo_ui_add_id_card"
        app:cornerRadius="12dp"
        app:icon="@drawable/eimzo_ui_ic_nfc"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    <!-- USB token "add" button kept in the binding for ABI compatibility,
         but hidden — USB token is sign-only and lives on the Home screen
         as a dedicated "USB token bilan imzolash" button. AddKeyFragment
         sets visibility = GONE on this in code as a defensive belt-and-
         braces (in case some downstream layout override re-enables it). -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddUsbToken"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/eimzo_ui_add_usb_token"
        app:cornerRadius="12dp"
        app:icon="@drawable/eimzo_ui_ic_usb"
        android:visibility="gone"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    <TextView
        android:id="@+id/tvNfcHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/eimzo_ui_bring_card_close"
        android:textAlignment="center"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:visibility="gone" />

</LinearLayout>
